[Desktop Entry]
Type=Application
Name=Redactly
GenericName=Photo Redactor
Comment=Detect and anonymize faces and license plates in images
Exec=Redactly %F
Icon=redactly
Terminal=false
Categories=Graphics;Photography;
MimeType=image/jpeg;image/png;image/bmp;image/tiff;image/webp;
Keywords=face;plate;blur;mosaic;anonymize;redact;privacy;
